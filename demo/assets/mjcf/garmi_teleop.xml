      <joint joint="teleop_arm_0_gripper_fr3_finger_joint2" coef="0.5"/>
    </fixed>
    <fixed name="right_gripper">
      <joint joint="teleop_arm_1_gripper_fr3_finger_joint1" coef="0.5"/>
      <joint joint="teleop_arm_1_gripper_fr3_finger_joint2" coef="0.5"/>
    </fixed>
    <fixed name="lift_0">
      <joint joint="teleop_lift_0_lower_joint" coef="0.5"/>
      <joint joint="teleop_lift_0_upper_joint" coef="0.5"/>
    </fixed>
  </tendon>

  <actuator>
    <position name="left_gripper" tendon="left_gripper" ctrlrange="0 0.04" kp="500" kv="10"/>
    <position name="right_gripper" tendon="right_gripper" ctrlrange="0 0.04" kp="500" kv="10"/>
  </actuator>

  <extension>
    <plugin plugin="mujoco.multiverse_connector">
      <instance name="mujoco_client">
        <config key="transport" value="zmq" />
        <config key="host" value="tcp://127.0.0.1" />
        <config key="server_port" value="7000" />
        <config key="client_port" value="7550" />
        <config key="world_name" value="world" />
        <config key="simulation_name" value="gami_teleop" />
        <config key="send" value="{'joint': ['joint_angular_position', 'joint_linear_position']}" />
        <config key="receive" value="{'head_ref': ['position', 'quaternion'], 'hand_left_ref': ['position', 'quaternion'], 'hand_right_ref': ['position', 'quaternion'], 'left_gripper': ['scalar'], 'right_gripper': ['scalar']}" />
      </instance>
    </plugin>
  </extension>
</mujoco>
