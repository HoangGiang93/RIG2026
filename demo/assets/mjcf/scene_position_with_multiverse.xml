<mujoco model="garmi_scene">

  <include file="scene_position.xml"/>

  <extension>
    <plugin plugin="mujoco.multiverse_connector">
      <instance name="mujoco_client">
        <config key="transport" value="zmq" />
        <config key="host" value="tcp://127.0.0.1" />
        <config key="server_port" value="7000" />
        <config key="client_port" value="7500" />
        <config key="world_name" value="world" />
        <config key="simulation_name" value="scene_position" />
        <config key="send" value="{'cube_1': ['position', 'quaternion'], 'cube_2': ['position', 'quaternion'], 'cube_3': ['position', 'quaternion'], 'cube_4': ['position', 'quaternion'], 'joint': ['joint_angular_position', 'joint_linear_position', 'joint_angular_velocity', 'joint_linear_velocity', 'joint_torque', 'joint_force']}" />
        <config key="receive" value="{
        'lift_0': ['cmd_joint_linear_position'],
        'head_pan_actuator': ['cmd_joint_angular_position'], 'head_tilt_actuator': ['cmd_joint_angular_position'],
        'arm_0_actuator1': ['cmd_joint_angular_position'], 'arm_0_actuator2': ['cmd_joint_angular_position'], 'arm_0_actuator3': ['cmd_joint_angular_position'], 'arm_0_actuator4': ['cmd_joint_angular_position'], 'arm_0_actuator5': ['cmd_joint_angular_position'], 'arm_0_actuator6': ['cmd_joint_angular_position'], 'arm_0_actuator7': ['cmd_joint_angular_position'],
        'arm_1_actuator1': ['cmd_joint_angular_position'], 'arm_1_actuator2': ['cmd_joint_angular_position'], 'arm_1_actuator3': ['cmd_joint_angular_position'], 'arm_1_actuator4': ['cmd_joint_angular_position'], 'arm_1_actuator5': ['cmd_joint_angular_position'], 'arm_1_actuator6': ['cmd_joint_angular_position'], 'arm_1_actuator7': ['cmd_joint_angular_position'],
        'left_gripper': ['scalar'], 'right_gripper': ['scalar']}"/>
      </instance>
    </plugin>
  </extension>

</mujoco>
